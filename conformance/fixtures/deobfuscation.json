  "decision_cases": [
    {
      "id": "redact_escalates_on_view_hit",
      "action": "redact",
      "via": "base64",
      "expect": "block",
      "note": "via present => raw text clean => span redaction would no-op; a 'redacted' record with the payload intact is a false compliance record."
    },
    {
      "id": "redact_escalates_any_view",
      "action": "redact",
      "via": "deobfuscated",
      "expect": "block"
    },
    {
      "id": "redact_unchanged_raw_hit",
      "action": "redact",
      "via": null,
      "expect": "redact"
    },
    {
      "id": "block_unchanged_view_hit",
      "action": "block",
      "via": "hex",
      "expect": "block"
    },
    {
      "id": "block_unchanged_raw_hit",
      "action": "block",
      "via": null,
      "expect": "block"
    },
    {
      "id": "detect_only_never_escalates",
      "action": "detect_only",
      "via": "percent",
      "expect": "detect_only",
      "note": "The operator chose detection-only; the view layer strengthens detection, never invents enforcement."
    },
    {
      "id": "detect_only_unchanged_raw",
      "action": "detect_only",
      "via": null,
      "expect": "detect_only"
    }
  ],
  "storage_cases": [
    {
      "id": "raw_hit_span_redaction",
      "text": "my ssn is 123-45-6789",
      "via": null,
      "expect": "my ssn is [REDACTED_SSN]",
      "note": "via absent: exactly redactBuiltinPii/redact_builtin_pii (typed span placeholders)."
    },
    {
      "id": "clean_text_identity",
      "text": "no pii here",
      "via": null,
      "expect": "no pii here"
    },
    {
      "id": "view_hit_whole_text_placeholder",
      "text": "bXkgc3NuIGlzIDEyMy00NS02Nzg5",
      "via": "base64",
      "expect": "[REDACTED:obfuscated]",
      "note": "via present: the payload has no locatable span in the raw text; the whole stored copy is replaced. detected_types + via on the event keep the record useful."
    },
    {
      "id": "view_hit_placeholder_any_method",
      "text": "whatever raw text",
      "via": "deobfuscated",
      "expect": "[REDACTED:obfuscated]"
    }
  ],
